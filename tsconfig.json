{
    "compilerOptions": {
        "target": "es2018",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": [
            "esnext"
        ],
        "outDir": "lib",
        "strict": true,
        "declaration": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": "./",
        "paths": {
            "@utils": [
                "src/utils/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "**/*.config.js",
    ],
    "exclude": [
        "node_modules"
    ],
}