{
  "name": "ryze-tello-sdk-ts",
  "version": "0.0.1",
  "description": "A lightweight and independent package to hook into a tello drone via node.js env",
  "private": false,
  "main": "index.js",
  "scripts": {
    "start": "tsc-watch --onSuccess \"node lib/index.js\"",
    "build": "tsc",
    "lint": "eslint src/**/*.ts --max-warnings=0",
    "format": "eslint src/**/*.ts --fix",
    "prepare": "husky install"
  },
  "keywords": [
    "tello",
    "drone",
    "tello-drone",
    "tello-javascript",
    "tello-typescript",
    "tello-nodejs",
    "dji",
    "dji-tello",
    "dji-tello-drone",
    "dji-tello-javascript",
    "dji-tello-typescript",
    "dji-tello-nodejs"
  ],
  "author": "Szymon Polanowski",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@types/node": "18.7.13",
    "@typescript-eslint/eslint-plugin": "5.35.1",
    "@typescript-eslint/parser": "5.35.1",
    "eslint": "^8.11.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^16.1.4",
    "eslint-plugin-import": "2.26.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.5.0",
    "ts-node": "10.9.1",
    "tsc-watch": "5.0.3",
    "typescript": "4.8.2"
  }
}
