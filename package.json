{
  "name": "ryze-tello-sdk-ts",
  "version": "0.0.1",
  "description": "A lightweight and independent package to hook into a tello drone via node.js env",
  "private": false,
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "format": "eslint src/**/*.ts --fix",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "prepare": "husky install"
  },
  "keywords": [
    "tello",
    "drone",
    "tello-drone",
    "tello-javascript",
    "tello-typescript",
    "tello-nodejs",
    "dji",
    "dji-tello",
    "dji-tello-drone",
    "dji-tello-javascript",
    "dji-tello-typescript",
    "dji-tello-nodejs"
  ],
  "author": "Szymon Polanowski",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@types/node": "^17.0.22",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "eslint": "^8.11.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^16.1.4",
    "eslint-plugin-import": "^2.25.4",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.7",
    "ts-node": "^10.7.0",
    "typescript": "^4.6.2"
  }
}
